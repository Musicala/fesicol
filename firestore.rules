rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Correos con permisos de ADMIN (lectura + escritura total)
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com',
        'imusicala@gmail.com',
        'musicalaasesor@gmail.com'
      ];
    }

    // Usuario autorizado: admin, o registrado en la colección /usuarios
    function isAuthorized() {
      return request.auth != null && (
        isAdmin() ||
        exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email))
      );
    }

    // Solo admins gestionan usuarios
    match /usuarios/{email} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }

    // Resto de datos: cualquier autorizado lee, solo admin escribe
    match /{document=**} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }
  }
}
